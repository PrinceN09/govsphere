{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.node.json",
  "compilerOptions": {
    // NestJS requires both decorator flags for dependency injection and
    // the @nestjs/swagger reflection metadata to work at runtime.
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "outDir": "./dist",
    // baseUrl is required for the paths aliases below to resolve correctly
    // relative to this tsconfig file, not the process cwd.
    "baseUrl": ".",
    "paths": {
      "@prinodia/config": ["../../packages/config/src/index.ts"],
      "@prinodia/database": ["../../packages/database/src/index.ts"],
      "@prinodia/types": ["../../packages/types/src/index.ts"],
      "@prinodia/auth": ["../../packages/auth/src/index.ts"],
      "@prinodia/utils": ["../../packages/utils/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "test"]
}
